# Optional: set a real Groq API key to get true LLM-generated content,
# translations, and sentiment analysis instead of the built-in mock fallback.
# Get a free key at https://console.groq.com/keys
GROQ_API_KEY=

# Change this in any real deployment.
JWT_SECRET=dev-secret-change-me-in-production

# Defaults to local SQLite file if unset.
